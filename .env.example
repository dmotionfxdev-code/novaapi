# Committed template — copy to .env for local development. .env itself is
# gitignored. Production secrets are injected by the deployment platform's
# secrets manager, never taken from a checked-in file (Infrastructure
# Architecture §12; Sprint 0 Review finding #28 / Remediation #28: values
# below are LOCAL-DEV-ONLY DEFAULTS and MUST NOT be reused in any shared,
# staging, or production environment).

ENVIRONMENT=development
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+asyncpg://georisk:georisk_dev@postgres:5432/georisk
DB_POOL_SIZE=10

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_RATELIMIT_URL=redis://redis:6379/2

STORAGE_BACKEND=minio
STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_ACCESS_KEY=georisk
STORAGE_SECRET_KEY=georisk_dev_minio
STORAGE_BUCKET_PREFIX=firas-dev

# shared_schema | schema_per_tenant — Infrastructure Architecture §5.
# Read by settings from Sprint 0 onward; only "shared_schema" is actually
# implemented until Roadmap Sprint 11.
TENANCY_MODE=shared_schema

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Empty in local dev = tracing exports to console only (Observability §22).
OTEL_EXPORTER_ENDPOINT=

POSTGRES_PASSWORD=georisk_dev
MINIO_ROOT_PASSWORD=georisk_dev_minio
