# NOVA GeoRisk Platform — PRODUCTION environment template for cPanel deployment
# (novaapi.novarex.co.tz). Copy to `.env` in the application's cPanel home
# directory and fill in real values — never commit the filled-in `.env` file.
#
# Every variable below corresponds EXACTLY to a field on `Settings`
# (src/georisk/settings.py) — pydantic-settings matches env var names to
# field names case-insensitively, so `DATABASE_URL` populates `database_url`,
# etc. Do not invent additional variable names (e.g. APP_ENV/APP_DEBUG/
# APP_URL/JWT_SECRET) that Settings does not define — they would be silently
# ignored (`extra="ignore"`), not an error, which is worse than a typo.

# --- Core ---
# "production" activates the guard in settings.py that REJECTS the
# development-only JWT_SECRET_KEY default outright — this must be set to
# "production" for a real deployment.
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Database (cPanel PostgreSQL) ---
# cPanel-provisioned PostgreSQL databases/users are usually prefixed with
# the cPanel account username, e.g. `cpaneluser_georisk` / `cpaneluser_geo`.
# Host is typically "localhost" for a same-server PostgreSQL instance.
DATABASE_URL=postgresql+asyncpg://CPANEL_DB_USER:CPANEL_DB_PASSWORD@localhost:5432/CPANEL_DB_NAME
DB_POOL_SIZE=10

# --- Redis ---
# Only required if this cPanel account has Redis available (many shared
# cPanel hosts do not provide Redis — see CPANEL_DEPLOYMENT_GUIDE.md for
# what degrades gracefully vs. what hard-requires it).
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_RATELIMIT_URL=redis://localhost:6379/2

# --- Object storage (declared since Sprint 0; not yet consumed by any
# context as of Sprint 14 — safe to leave at these placeholders until a
# future sprint actually wires MinIO/S3 in) ---
STORAGE_BACKEND=minio
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=changeme
STORAGE_SECRET_KEY=changeme
STORAGE_BUCKET_PREFIX=georisk-prod

# --- Multi-tenancy ---
# Only "shared_schema" is actually implemented (see contexts/identity/README.md).
TENANCY_MODE=shared_schema

# --- CORS ---
# Explicit origin(s) only — NEVER "*" here. "*" combined with this app's
# allow_credentials=True is a real cross-tenant credential-leak vector
# (see SECURITY_REVIEW.md item 6). Comma-separate multiple origins.
CORS_ALLOWED_ORIGINS=https://novarex.co.tz,https://www.novarex.co.tz

# --- Observability (optional — empty means console-only tracing) ---
OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=georisk-api

# --- JWT / Identity (Sprint 1) ---
# REQUIRED. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# The app REFUSES to start in ENVIRONMENT=production if this is left at its
# insecure development default — this is not optional.
JWT_SECRET_KEY=REPLACE_WITH_A_REAL_HIGH_ENTROPY_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=28800

# --- SMTP (Notification & Early Warning email channel, Sprint 11) ---
# Leave SMTP_HOST empty to keep the email channel honestly "not configured"
# (every send reports an immediate, clean failure) rather than guessing at
# credentials. Fill in only if a real mailbox/relay is available to this
# cPanel account (cPanel's own mail service, or an external SMTP relay).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=alerts@novarex.co.tz
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=5.0

# --- Data Acquisition: USGS / NASA / Copernicus (Sprint 13) ---
# All optional — each provider stays honestly "not configured" (immediate,
# clean failure, never a fabricated response) until real credentials/base
# URLs are supplied.
USGS_API_BASE_URL=
USGS_API_KEY=
NASA_API_BASE_URL=
NASA_API_KEY=
COPERNICUS_API_BASE_URL=
COPERNICUS_API_KEY=
ACQUISITION_HTTP_TIMEOUT_SECONDS=30.0

# --- Data Acquisition: Google Earth Engine (Sprint 14) ---
# Requires a real Google Cloud service account with the Earth Engine API
# enabled on its project. GEE_SERVICE_ACCOUNT_PRIVATE_KEY is the FULL
# contents of the downloaded service-account JSON key file, minified to a
# single line (this is passed directly as `ee.ServiceAccountCredentials`'s
# `key_data` argument — see infrastructure/gee_connector.py). Leave both
# empty to keep the GEE provider honestly "not configured."
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_PRIVATE_KEY=
GEE_PROJECT_ID=

# --- NOT read by the application (docker-compose-only provisioning vars —
# omit entirely on cPanel; kept here only as a comment for anyone diffing
# against the docker .env.example) ---
# POSTGRES_PASSWORD=... (docker-compose Postgres container init only)
# MINIO_ROOT_PASSWORD=... (docker-compose MinIO container init only)
